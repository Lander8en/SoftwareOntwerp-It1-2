@startuml
title Use Case 7: Delete Column
hide footbox

actor User
participant MainWindow
participant SubwindowManager
participant MouseInteractionDispatcher
participant EditAnySubwindowStrategy
participant TableDesignSubwindow
participant ColumnsController
participant Table
participant ColumnRepository

== Select Column ==
User -> MainWindow : handleMouseEvent(MOUSE_CLICKED, x, y, 1)
activate MainWindow
MainWindow -> SubwindowManager : handleMouseEvent(...)
activate SubwindowManager
SubwindowManager -> SubwindowManager : findSubwindowAt(...)
SubwindowManager --> SubwindowManager : target
SubwindowManager -> SubwindowManager : bringToFront(target)
SubwindowManager -> MouseInteractionDispatcher : dispatchMouseEvent(...)
activate MouseInteractionDispatcher
MouseInteractionDispatcher -> EditAnySubwindowStrategy : wantsToHandle(...)
activate EditAnySubwindowStrategy
EditAnySubwindowStrategy --> MouseInteractionDispatcher : true
deactivate EditAnySubwindowStrategy
MouseInteractionDispatcher -> EditAnySubwindowStrategy : handle(...)
activate EditAnySubwindowStrategy
EditAnySubwindowStrategy -> TableDesignSubwindow : handleMouseEvent(...)
activate TableDesignSubwindow
TableDesignSubwindow -> TableDesignSubwindow : getColumnIndexFromY(...)
TableDesignSubwindow --> TableDesignSubwindow : index
TableDesignSubwindow -> TableDesignSubwindow : isInSelectionMargin(...)
TableDesignSubwindow --> TableDesignSubwindow : true
note right of TableDesignSubwindow : selectedColumnIndex = index
TableDesignSubwindow --> EditAnySubwindowStrategy : void
deactivate TableDesignSubwindow
EditAnySubwindowStrategy --> MouseInteractionDispatcher : void
deactivate EditAnySubwindowStrategy
MouseInteractionDispatcher --> SubwindowManager : void
deactivate MouseInteractionDispatcher
SubwindowManager --> MainWindow : void
deactivate SubwindowManager
MainWindow --> User
deactivate MainWindow

== Press Delete ==
User -> MainWindow : handleKeyEvent(KEY_PRESSED, VK_DELETE, ...)
activate MainWindow
MainWindow -> SubwindowManager : handleKeyEvent(...)
activate SubwindowManager
SubwindowManager -> TableDesignSubwindow : handleKeyEvent(...)
activate TableDesignSubwindow
TableDesignSubwindow -> ColumnsController : columnsRequest()
activate ColumnsController
ColumnsController -> Table : getColumnRepository()
activate Table
Table -> ColumnRepository : getColumns()
activate ColumnRepository
ColumnRepository --> Table : columns
deactivate ColumnRepository
Table --> ColumnsController : columns
deactivate Table
ColumnsController --> TableDesignSubwindow : columns
deactivate ColumnsController
TableDesignSubwindow -> ColumnsController : handleDeleteColumnRequest(column)
activate ColumnsController
ColumnsController -> Table : deleteColumn(column)
activate Table
Table -> ColumnRepository : remove(column)
activate ColumnRepository
ColumnRepository --> Table : void
deactivate ColumnRepository
Table -> Table : removeValueForColumnFromAllRows()
Table --> ColumnsController : void
deactivate Table
ColumnsController --> TableDesignSubwindow : void
deactivate ColumnsController
TableDesignSubwindow --> SubwindowManager : void
deactivate TableDesignSubwindow
SubwindowManager --> MainWindow : void
deactivate SubwindowManager
MainWindow --> User
deactivate MainWindow
@enduml