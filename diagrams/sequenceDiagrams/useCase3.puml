@startuml
hide footbox
title Use Case 3: Delete Table

actor User
participant MainWindow
participant SubwindowManager
participant MouseInteractionDispatcher
participant EditAnySubwindowStrategy
participant TableSubwindow
participant TablesController

== Select Table ==
User -> MainWindow : handleMouseEvent(MOUSE_CLICKED, x, y, 1)
activate MainWindow
MainWindow -> SubwindowManager : handleMouseEvent(...)
activate SubwindowManager
SubwindowManager -> SubwindowManager : findSubwindowAt(...) 
SubwindowManager --> SubwindowManager : target
SubwindowManager -> SubwindowManager : bringToFront(target)
SubwindowManager -> MouseInteractionDispatcher : dispatchMouseEvent(...)
activate MouseInteractionDispatcher
MouseInteractionDispatcher -> EditAnySubwindowStrategy : wantsToHandle(...)
activate EditAnySubwindowStrategy
EditAnySubwindowStrategy --> MouseInteractionDispatcher : true
deactivate EditAnySubwindowStrategy
MouseInteractionDispatcher -> EditAnySubwindowStrategy : handle(...)
activate EditAnySubwindowStrategy
EditAnySubwindowStrategy -> TableSubwindow : handleMouseEvent(...)
activate TableSubwindow
TableSubwindow -> TablesController : tablesRequest()
activate TablesController
TablesController -> TableRepository : getTables()
activate TableRepository
TableRepository --> TablesController : tables
deactivate TableRepository
TablesController --> TableSubwindow : tables
deactivate TablesController
TableSubwindow -> TableSubwindow : getTableIndexFromY(...)
TableSubwindow --> TableSubwindow : index
TableSubwindow -> TableSubwindow : isInSelectionMargin(...)
TableSubwindow --> TableSubwindow : true
note right of TableSubwindow : selectedTableIndex = index
TableSubwindow --> EditAnySubwindowStrategy : void
deactivate TableSubwindow
EditAnySubwindowStrategy --> MouseInteractionDispatcher : void
deactivate EditAnySubwindowStrategy
MouseInteractionDispatcher --> SubwindowManager : void
deactivate MouseInteractionDispatcher
SubwindowManager --> MainWindow : void
deactivate SubwindowManager
MainWindow --> User
deactivate MainWindow

== Press Delete ==
User -> MainWindow : handleKeyEvent(KEY_PRESSED, VK_DELETE, ...)
activate MainWindow
MainWindow -> SubwindowManager : handleKeyEvent(...)
activate SubwindowManager
SubwindowManager -> TableSubwindow : handleKeyEvent(...)
activate TableSubwindow
TableSubwindow -> TablesController : tablesRequest()
activate TablesController
TablesController -> TableRepository : getTables()
activate TableRepository
TableRepository --> TablesController : tables
deactivate TableRepository
TablesController --> TableSubwindow : tables
deactivate TablesController
TableSubwindow -> TablesController : handleDeleteTableRequest(table)
activate TablesController
TablesController -> TableRepository : remove(table)
activate TableRepository
TableRepository --> TablesController : void
deactivate TableRepository
TablesController --> TableSubwindow : void
deactivate TablesController
TableSubwindow --> SubwindowManager : void
deactivate TableSubwindow
SubwindowManager --> MainWindow : void
deactivate SubwindowManager
MainWindow --> User
deactivate MainWindow

@enduml